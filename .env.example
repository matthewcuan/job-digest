# Copy to .env and fill in real values. NEVER commit the real .env (it is .gitignored).
# In GitHub Actions these are provided as repository Secrets, not a file.

# --- Email (Gmail example; see README for app-password steps) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password
EMAIL_TO=you@gmail.com

# --- Optional: residential proxy for JobSpy if GitHub IPs get blocked ---
# Format: user:pass@host:port  (or just host:port)
# PROXY_URL=

# --- State persistence ---
# file = local dev (just reads/writes .state/seen_jobs.jsonl)
# repo = GitHub Actions (the workflow commits .state/ to the `state` branch)
STORAGE_BACKEND=file
STATE_DIR=.state

# Optional: auto-drop seen entries older than N days at the end of each run, so the
# seen-store (and its state-branch git history) stays small. Unset = keep forever.
# STATE_RETENTION_DAYS=90
