# Copy to config.yaml and edit. This file is committed; secrets live in .env / GitHub
# Secrets only (see .env.example).

search:
  # must_have = AND filter: a job must contain EVERY term (in title or description) to
  # survive. These are also joined into the query string sent to the boards.
  must_have: ["python", "engineer"]
  # nice_to_have = ranking boost only; never excludes a job.
  nice_to_have: ["backend", "django", "remote"]

  # exclude = title blocklist. A job whose TITLE contains any of these (whole-word match,
  # always title-only) is dropped even if it passed must_have. Use it to keep a broad
  # must_have like "engineer" while removing unwanted disciplines. Whole-word so short
  # tokens are safe: "rf" matches "RF Engineer", not "Performance Engineer".
  exclude: []   # e.g. ["mechanical", "electrical", "sales", "field", "hardware"]

  # Target specific employers on the keyword-search boards (mainly Indeed, which honors a
  # company: filter). Use this to chase big companies that AREN'T on the ATS/Workday
  # adapters — e.g. Apple, Microsoft, Google, Amazon, Meta, Tesla. One Indeed search runs
  # per company (so keep the list focused). Empty = search all employers.
  target_companies: []   # e.g. ["Apple", "Google", "Amazon", "Meta"]

  # How must_have terms are matched. Defaults below = broadest recall.
  #   match_mode:   substring  -> "engineer" also matches "engineering"/"engineers" (loose)
  #                 word       -> whole word/phrase only: "engineer" != "engineering" (precise)
  #   match_fields: title_and_description -> match either field (most results)
  #                 title               -> match the job TITLE only (fewest false positives)
  # PRECISION RECIPE: to stop e.g. a sales role matching "engineer" because its description
  # mentions engineers, use `match_fields: title` (and/or `match_mode: word`).
  match_mode: substring
  match_fields: title_and_description

  location: "Remote"
  # Client-side location filter (ATS boards ignore the search `location` above and return a
  # company's whole global board, so filter here). Whole-word, case-insensitive; a blank/
  # unknown location is always kept.
  #   location_excludes -> blocklist: drop jobs whose location matches any term (loose).
  #   location_includes -> allowlist: if set, keep ONLY jobs whose location matches (strict).
  location_includes: []    # e.g. ["United States", "USA", "Remote", "California"]
  location_excludes: []    # e.g. ["India", "Australia", "United Kingdom", "Canada"]
  work_mode: remote        # any | remote | hybrid | onsite
  experience_level: null   # lenient: drops only clear senior-signal titles (senior/staff/
                           # principal/lead/director/vp/manager); keeps early/mid/unlabeled
  date_posted_hours: 168   # keep jobs newer than this (168 = 1 week); null = no limit
  salary_min: null         # annual; only excludes jobs that DO list a lower salary
  job_type: fulltime       # fulltime | parttime | contract | temporary | internship | null
  distance: 50             # miles (JobSpy boards)
  country: usa             # country_indeed — required by Indeed & Glassdoor

sources:
  # --- JobSpy-backed boards (best-effort; often blocked from CI IPs) ---
  google:
    enabled: false         # disabled: Google withholds its jobs-widget markup from
                           # datacenter/CI IPs ("initial cursor not found"), so it
                           # returns 0. Enable only behind a residential PROXY_URL.
    limit: 25
  indeed:
    enabled: true          # most tolerant scraper from a single/cloud IP
    limit: 25
  linkedin:
    enabled: false         # rate-limits fast without a proxy
    limit: 25
  glassdoor:
    enabled: false         # needs a resolvable location; frequently 403s
    limit: 25
  ziprecruiter:
    enabled: false         # US/Canada only
    limit: 25

  # --- ATS public APIs (most reliable from CI; add your target companies' board slugs) ---
  # Find the slug in the careers URL:
  #   greenhouse -> job-boards.greenhouse.io/<slug>
  #   lever      -> jobs.lever.co/<slug>
  #   ashby      -> jobs.ashbyhq.com/<slug>   (CASE-SENSITIVE)
  greenhouse:
    enabled: true
    limit: 50
    companies: ["greenhouse"]   # example slug that returns live data; replace with yours
  lever:
    enabled: true
    limit: 50
    companies: ["leverdemo"]    # example slug
  ashby:
    enabled: true
    limit: 50
    companies: ["Ashby"]        # example slug (case-sensitive)

  # Workday: used by many large employers. `companies` here are full CAREER-SITE URLs
  # (copy from the browser), NOT slugs. Of the "Magnificent 7", only Nvidia is on Workday
  # (the others run custom portals). Add others like Salesforce/Adobe the same way.
  # Note: Workday fetches per-job detail, so keep `limit` modest.
  workday:
    enabled: false
    limit: 15
    companies:
      - "https://nvidia.wd5.myworkdayjobs.com/en-US/NVIDIAExternalCareerSite"

dedup:
  fuzzy_threshold: 88      # rapidfuzz score 0-100; >= this collapses near-duplicate postings

# Optional LLM relevance scoring. Each NEW job is scored 0-100 against `ideal_role`; the
# score folds into ranking (and `min_score` can hard-filter weak matches). Disabled by
# default — when off, unconfigured, or erroring, the pipeline keyword-ranks as usual.
# The Anthropic backend needs an ANTHROPIC_API_KEY secret (see .env.example).
llm:
  enabled: false
  provider: anthropic        # anthropic  (openai_compatible / local Ollama planned)
  model: claude-haiku-4-5    # cheap + fast; per-job scoring is a bounded judgement task
  ideal_role: |
    Describe your ideal role in prose — seniority, domain, stack, location, comp, IC vs.
    manager. The model scores each posting against this, so be specific.
  min_score: null            # null = de-rank only (never drops); int (e.g. 40) = hard-filter below it
  weight: 1.0                # ranking influence (0 = scored + shown in the email but no reorder)
  max_jobs: 100              # safety cap on scoring calls per run (logged if exceeded)
  concurrency: 4             # parallel scoring calls (set 1 for a single local GPU)

email:
  smtp_host: smtp.gmail.com   # SMTP_HOST env var overrides this if set
  smtp_port: 587
  sender: "you@gmail.com"
  recipient: "you@gmail.com"  # EMAIL_TO env var overrides this if set
  use_tls: true               # STARTTLS (port 587, the Gmail default)
  use_ssl: false              # implicit TLS / SMTPS (port 465); auto-enabled when port == 465
  subject_prefix: "[Job Digest]"
  send_empty_digest: false    # email even when there are zero new jobs
  send_on_total_failure: true # email a failure summary when EVERY source failed
