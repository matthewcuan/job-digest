<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background:#f4f5f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1a1a;">
  <div style="max-width:680px;margin:0 auto;padding:24px;">

    <h1 style="font-size:20px;margin:0 0 4px;">Job Digest</h1>
    <p style="color:#666;font-size:13px;margin:0 0 16px;">
      {{ generated_at }} &middot; {{ total_new }} new job{{ '' if total_new == 1 else 's' }}
    </p>

    <!-- Source health -->
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;">
      <strong>Sources</strong>
      <div style="margin-top:6px;line-height:1.8;">
        {% for src, info in source_health.items() %}
          <span style="display:inline-block;margin-right:12px;white-space:nowrap;">
            {% if not info.ok %}🔴{% elif info.near_empty %}⚪{% else %}🟢{% endif %}
            {{ src }} ({{ info.count }}){% if not info.ok %} — failed{% elif info.near_empty %} — 0 results{% endif %}
          </span>
        {% endfor %}
      </div>
      {% if failed_sources %}
        <div style="margin-top:8px;color:#b91c1c;font-size:12px;">
          ⚠ Failed:
          {% for src, info in source_health.items() if not info.ok %}
            {{ src }}{% if info.error %} ({{ info.error }}){% endif %}{% if not loop.last %};{% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if total_new == 0 %}
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:16px;font-size:14px;color:#444;">
        {% if all_failed %}
          Every source failed on this run — see the failure summary above.
        {% else %}
          No new jobs this run.
        {% endif %}
      </div>
    {% endif %}

    {% for source, jobs in groups %}
      <h2 style="font-size:15px;text-transform:capitalize;margin:20px 0 8px;border-bottom:2px solid #e5e7eb;padding-bottom:4px;">
        {{ source }} <span style="color:#999;font-weight:normal;">({{ jobs|length }})</span>
      </h2>
      {% for job in jobs %}
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:14px 16px;margin-bottom:10px;">
          <div style="font-size:15px;font-weight:600;margin-bottom:3px;">{{ job.title }}</div>
          <div style="font-size:13px;color:#555;margin-bottom:8px;">
            {{ job.company }}{% if job.location %} &middot; {{ job.location }}{% endif %}
            {% if job.salary %} &middot; {{ job.salary }}{% endif %}
            &middot; {% if job.posted_date %}{{ job.posted_date.strftime('%Y-%m-%d') }}{% else %}date unknown{% endif %}
          </div>
          {% if job.description_snippet %}
            <div style="font-size:13px;color:#333;line-height:1.5;margin-bottom:10px;">{{ job.description_snippet }}</div>
          {% endif %}
          <a href="{{ job.url|safe_url }}" style="display:inline-block;background:#2563eb;color:#fff;text-decoration:none;font-size:13px;font-weight:600;padding:8px 16px;border-radius:6px;">Apply &rarr;</a>
          <span style="font-size:11px;color:#999;margin-left:10px;">source: {{ job.source }}</span>
        </div>
      {% endfor %}
    {% endfor %}

    <p style="color:#aaa;font-size:11px;margin-top:24px;border-top:1px solid #e5e7eb;padding-top:12px;">
      fetched {{ stats.fetched }} &middot; after dedup {{ stats.after_dedup }} &middot;
      after filter {{ stats.after_filter }} &middot; already-seen skipped {{ stats.seen_skipped }}
    </p>

  </div>
</body>
</html>
